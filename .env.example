# ===========================================================
# Inkscroller Backend — environment variable reference
# ===========================================================
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in the values below.
# 3. NEVER commit .env to version control.
#
# CI/CD: See SECURITY_PUBLIC_READINESS.md for how to inject
# these values via GitHub Secrets in automated pipelines.
# ===========================================================

# -- Core ----------------------------------------------------
DEBUG=false
# CORS_ORIGINS: comma-separated list of allowed origins, or * for all.
# In production, restrict to your frontend domain(s).
CORS_ORIGINS=*

# -- Upstream APIs --------------------------------------------
MANGADEX_BASE_URL=https://api.mangadex.org
JIKAN_BASE_URL=https://api.jikan.moe/v4
# Enable Jikan enrichment for manga details (default: true)
ENABLE_JIKAN_ENRICHMENT=true
# In-memory cache TTL in seconds (default: 5 minutes)
CACHE_TTL_SECONDS=300

# -- Firebase Auth --------------------------------------------
# Your Firebase project ID (from Firebase Console → Project settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to the Firebase service-account JSON key file.
# Download from Firebase Console → Project settings → Service accounts.
#
# LOCAL DEVELOPMENT: set this to the path of your downloaded key file.
# CLOUD RUN / CI: leave empty — Application Default Credentials (ADC)
#   will be used automatically via Workload Identity or the attached
#   service account. See SECURITY_PUBLIC_READINESS.md §3.
#
# NEVER commit the actual key file to version control.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# -- SQLite persistence ---------------------------------------
# Relative or absolute path for the SQLite database file.
# In Cloud Run, use a mounted volume or Cloud SQL for persistence.
DB_PATH=./inkscroller.db
